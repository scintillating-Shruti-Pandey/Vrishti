# =================================
# Vṛṣṭi Server Environment Variables
# =================================

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vrishti?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_key_here_change_me

# Server Port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin Registration Secret Key
ADMIN_SECRET_KEY=vrishti_admin_2024_secret

# Node Environment
NODE_ENV=development
